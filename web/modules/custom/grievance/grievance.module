/**
 * Implements hook_cron().
 */
function grievance_cron() {
  // Create the worker instance.
  $worker = \Drupal::service('plugin.manager.queue_worker')->createInstance('grievance_submission');

  if (method_exists($worker, 'processBatch')) {
    // Process up to 10 items per run, with max 5 concurrent requests.
    $worker->processBatch(10, 5);
  }
  else {
    // Fallback: process one-by-one (legacy behavior).
    $queue = \Drupal::service('queue')->get('grievance_submission');
    while ($item = $queue->claimItem()) {
      try {
        $worker->processItem($item->data);
        $queue->deleteItem($item);
      }
      catch (\Exception $e) {
        $queue->releaseItem($item);
      }
    }
  }
}
