<form
	{{ form.attributes }}>
	<!-- Header -->
	<div class="mx-auto max-w-screen-xl">
		<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 py-10">
			<div>
				<a href="/manage-address" class="text-gray-700 hover:text-yellow-600">
					<svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class="bi bi-arrow-left" viewbox="0 0 16 16">
						<path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
					</svg>
				</a>
			</div>
			<div class="text-center flex-1">
				<h1 class="text-3xl sm:text-4xl md:text-5xl font-nevis">
					{{ form['#is_edit'] ? 'Edit Address'|t : 'Add Address'|t }}
				</h1>
			</div>
		</div>
	</div>

	<!-- Form Container -->
	<div
		class="mx-auto max-w-screen-xl p-6 bg-white rounded-xl shadow-md space-y-6">

		<!-- Map Section -->
		<div class="add-address gap-4 relative">
			<div id="mapDiv" class="map" style="border:0; width:100%; height: 360px">
				<img src="/themes/custom/engage_theme/images/location_pin.png" class="get_lat_lang absolute top-3 left-72 bg-white h-6 w-6 p-0.5 z-20 border s:h-7 s:left-64 xs:left-64 xs:h-7" alt="location">
			</div>
			<p class="add-address-note">Note :- Place the pointer at your required address</p>
		</div>

		<!-- Input Fields -->
		<div
			class="grid grid-cols-1 md:grid-cols-2 gap-6">
			<!-- Postal Code -->
			<div>
				{{ form.postal_code }}
				{% if form.postal_code['#errors'] %}
					<p class="text-red-600 text-sm mt-1">{{ form.postal_code['#errors'] }}</p>
				{% endif %}
			</div>

			<!-- Flat / House Number -->
			<div>
				{{ form.flat }}
				{% if form.flat['#errors'] %}
					<p class="text-red-600 text-sm mt-1">{{ form.flat['#errors'] }}</p>
				{% endif %}
			</div>

			<!-- Area -->
			<div>
				{{ form.area }}
				{% if form.area['#errors'] %}
					<p class="text-red-600 text-sm mt-1">{{ form.area['#errors'] }}</p>
				{% endif %}
			</div>

			<!-- Landmark -->
			<div>
				{{ form.landmark }}
				{% if form.landmark['#errors'] %}
					<p class="text-red-600 text-sm mt-1">{{ form.landmark['#errors'] }}</p>
				{% endif %}
			</div>

			<!-- Country -->
			<div>
				{{ form.country }}
				{% if form.country['#errors'] %}
					<p class="text-red-600 text-sm mt-1">{{ form.country['#errors'] }}</p>
				{% endif %}
			</div>

			<!-- Address Type Dropdown -->
			<div>
				{{ form.address_type }}
				{% if form.address_type['#errors'] %}
					<p class="text-red-600 text-sm mt-1">{{ form.address_type['#errors'] }}</p>
				{% endif %}
			</div>
		</div>

		<!-- Submit Button -->
		<div class="submit-btns btns flex lg:gap-8 mt-5 flex-col sm:flex-row s:gap-5 xs:gap-5">
			{{ form.actions }}
		</div>

		<!-- Hidden elements (form ID, token, etc.) -->
		{{ form|without('postal_code', 'flat', 'area', 'landmark', 'country', 'address_type', 'actions') }}
	</div>
</form>
