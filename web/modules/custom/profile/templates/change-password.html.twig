<div
	class="min-h-screen bg-cover bg-center flex flex-col items-center justify-center" id="change-password-form-wrapper">
	<!-- Row wrapper: arrow + form -->
	<div
		class="flex flex-col mx-auto w-full max-w-md px-4">
		<!-- Left: Arrow -->
		<div class="flex-shrink-0 mr-8 pb-6">
			<img src="themes/custom/engage_theme/images/Profile/white-arrow-left.svg" alt="Back" class="cursor-pointer w-10 h-10 xs:w-8 xs:h-8" onclick="window.location.href='my-account'">
		</div>
		<!-- Center: Form -->
		<div class="p-12 bg-white shadow-md rounded-lg w-full mx-auto">
			<h2 class="text-2xl font-semibold mb-6 text-center">Change Password</h2>
			<div class="mb-6">
				<p class="text-gray-600 text-sm">Please create a new password.</p>
			</div>
			<!-- Old Password -->
			<div class="relative mb-4">
				{{ include('@engage_theme/components/form/field--floating-text.html.twig', { field: form.old_password }) }}
				{# <span class="absolute z-10 right-3 top-[1.1rem]">
									<img src="themes/custom/engage_theme/images/Profile/hide-eye.svg" class="cursor-pointer hide-eye-old">
									<img src="themes/custom/engage_theme/images/Profile/show-eye.svg" class="cursor-pointer show-eye-old" hidden>
								</span> #}
			</div>
			<!-- New Password -->
			<div class="relative mb-4">
				{{ include('@engage_theme/components/form/field--floating-text.html.twig', { field: form.new_password }) }}
				{# <span class="absolute z-10 right-3 top-[1.1rem]">
									<img src="themes/custom/engage_theme/images/Profile/hide-eye.svg" class="cursor-pointer hide-eye-new">
									<img src="themes/custom/engage_theme/images/Profile/show-eye.svg" class="cursor-pointer show-eye-new" hidden>
								</span> #}
				<div id="password-tooltip-new" class="absolute z-50 mt-2 left-0 invisible opacity-0 transition-opacity duration-300 ease-in-out bg-white border border-gray-300 p-4 rounded-lg shadow text-sm w-full max-w-md">
					<p class="font-semibold mb-2 text-base">Password must contain:</p>
					<ul class="list-disc ml-5 space-y-1">
						<li id="rule-length-new" class="text-red-600">At least 8 characters</li>
						<li id="rule-uppercase-new" class="text-red-600">At least one uppercase letter</li>
						<li id="rule-lowercase-new" class="text-red-600">At least one lowercase letter</li>
						<li id="rule-number-new" class="text-red-600">At least one number</li>
						<li id="rule-special-new" class="text-red-600">At least one special character (@!$#%^&*)</li>
					</ul>
				</div>
			</div>
			<!-- Confirm Password -->
			<div class="relative mb-4">
				{{ include('@engage_theme/components/form/field--floating-text.html.twig', { field: form.confirm_password }) }}
				{# <span class="absolute z-10 right-3 top-[1.1rem]">
									<img src="themes/custom/engage_theme/images/Profile/hide-eye.svg" class="cursor-pointer hide-eye-con">
									<img src="themes/custom/engage_theme/images/Profile/show-eye.svg" class="cursor-pointer show-eye-con" hidden>
								</span> #}
				<div id="password-tooltip-confirm" class="absolute z-50 mt-2 left-0 invisible opacity-0 transition-opacity duration-300 ease-in-out bg-white border border-gray-300 p-4 rounded-lg shadow text-sm w-full max-w-md">
					<p class="font-semibold mb-2 text-base">Password must contain:</p>
					<ul class="list-disc ml-5 space-y-1">
						<li id="rule-length-confirm" class="text-red-600">At least 8 characters</li>
						<li id="rule-uppercase-confirm" class="text-red-600">At least one uppercase letter</li>
						<li id="rule-lowercase-confirm" class="text-red-600">At least one lowercase letter</li>
						<li id="rule-number-confirm" class="text-red-600">At least one number</li>
						<li id="rule-special-confirm" class="text-red-600">At least one special character (@!$#%^&*)</li>
						<li id="passmatch">Passwords must match</li>
					</ul>
				</div>
			</div>
			<!-- Submit Button -->
			<div class="flex flex-col sm:flex-row gap-8">
				<div>{{ form.actions.submit }}</div>
			</div>
		</div>
	</div>
	{{ form.form_build_id }}
	{{ form.form_token }}
	{{ form.form_id }}
</div>
