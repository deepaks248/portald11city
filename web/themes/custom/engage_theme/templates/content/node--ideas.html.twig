<div class="container ideas_page mx-auto sm:p-5 md:px-20 md:pb-20 relative xs:p-5 xs:mt-0 xs:mb-0 p-5 s:mt-0 s:mb-0 s:hidden xs:hidden">

    <div class="main-heading flex justify-between items-center">

        <button type="button" onclick="history.back()" class="cursor-pointer">
            <img class="object-contain sm:w-7 s:w-5 xs:w-5"
                 src="{{ file_url('themes/custom/engage_theme/images/Profile/reverse-arrow.svg') }}"
                 alt="Go back">
        </button>

        <h1 class="md:text-5xl text-4xl text-center md:mt-12 md:mb-20 mt-8 mb-8 font-bold s:my-3 xs:my-3">
            Idea
        </h1>

        <div></div>
    </div>

    <div class="blogs">
        <div class="card blog-page">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <div class="relative">
                    {% set uri = node.field_idea_image.value %}
                    <img src="{{ file_url(uri) }}"
                         alt="{{ node.title.value }}"
                         class="w-full h-full object-cover rounded-lg ideas-page-img">
                </div>

                <div>
                    <h1 class="card-title text-3xl text-dark font-semibold font-['Open_Sans'] text-[#414141] opacity-90">
                        {{ node.title.value }}
                    </h1>

                    <ul>
                        {% for item in node.field_ideas_categories %}
                            <li>
                                <h2 class="card-title text-xl font-normal font-['Open_Sans'] text-[#676767] opacity-80">
                                    {{ item.entity.label }}
                                </h2>
                            </li>
                        {% endfor %}
                    </ul>

                    <div class="flex justify-between items-center">
                        <p class="text-base text-all_font_color font-xs font-['Open_Sans'] minlines s:text-base xs:text-sm my-3 text-[#676767] opacity-80">
                            By {{ node.field_idea_author.value }}
                        </p>
                    </div>

                    <div class="soc_share min-h-[122px]">
                        <span class="sh_icon inline-block relative md:-top-[30px]">
                            {# Share Icon SVG (unchanged) #}
                            {{ include('@engage_theme/icons/share-icon.svg') }}
                        </span>

                        <div class="share_icons inline-block relative ml-[5px] bg-white border border-[#ddd] p-5 mb-[30px]">

                            <a class="inline-block text-[10px] font-normal text-[#918c8c] mr-5 cursor-pointer"
                               href="https://www.facebook.com/sharer/sharer.php?u={{ webportalUrl }}node/{{ node.id }}"
                               target="_blank"
                               rel="noopener noreferrer">
                                <img class="w-[35px] mx-auto"
                                     src="{{ file_url('themes/custom/engage_theme/images/Ideas/facebook.png') }}"
                                     alt="Share on Facebook">
                                <span class="block">Facebook</span>
                            </a>

                            <a class="inline-block text-[10px] font-normal text-[#918c8c] mr-5 cursor-pointer"
                               href="https://twitter.com/share?text={{ node.title.value }}&url={{ webportalUrl }}node/{{ node.id }}"
                               target="_blank"
                               rel="noopener noreferrer">
                                <img class="w-[35px] mx-auto"
                                     src="{{ file_url('themes/custom/engage_theme/images/Ideas/twitter.png') }}"
                                     alt="Share on Twitter">
                                <span class="block">Twitter</span>
                            </a>

                            <a class="inline-block text-[10px] font-normal text-[#918c8c] mr-5 cursor-pointer"
                               href="https://www.linkedin.com/sharing/share-offsite/?url={{ webportalUrl }}node/{{ node.id }}"
                               target="_blank"
                               rel="noopener noreferrer">
                                <img class="w-[35px] mx-auto"
                                     src="{{ file_url('themes/custom/engage_theme/images/Ideas/linkedin.png') }}"
                                     alt="Share on LinkedIn">
                                <span class="block">LinkedIn</span>
                            </a>

                            <button type="button"
                                    class="inline-block text-[10px] font-normal text-[#918c8c] mr-5 cursor-pointer"
                                    onclick="navigator.clipboard.writeText('{{ webportalUrl }}node/{{ node.id }}'); copied();"
                                    aria-label="Copy link">
                                <span class="copy_link bg-[#333] block p-[10px] rounded-full w-[35px] mx-auto">
                                    <img class="w-[35px] mx-auto"
                                         src="{{ file_url('themes/custom/engage_theme/images/Ideas/copy.png') }}"
                                         alt="Copy Link">
                                </span>
                                <span class="copied_link">Copy Link</span>
                            </button>

                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-10">
                        <div>
                            Posted on : {{ node.created.value|date("d/m/Y") }}
                        </div>

                        <div class="rates float-right rating_vote">
                            {% if logged_in %}
                                {{ content.field_rating }}
                            {% else %}
                                <a href="user-login"
                                   style="color:#59b1fc;text-decoration:underline;"
                                   onclick="document.querySelector('.login-btn').click(); return false;">
                                    Login to rate this Idea
                                </a>
                            {% endif %}
                        </div>
                    </div>

                </div>
            </div>

            <div class="card-desc details_desc text-lg font-normal font-['Open_Sans'] text-[#676767] mt-4 min-h-[73px] line-clamp-3 !leading-8">
                {{ node.field_idea_content.value | raw }}
            </div>

            <div class="ideas_comment">
                {{ content.field_ideas_comments }}
            </div>

        </div>
    </div>
</div>



{# ---------------- MOBILE VIEW ---------------- #}

<div class="container blog_mobile scrolling mx-auto s:p-0 xs:p-5 hidden s:block xs:block">

    <div class="main-heading flex justify-between items-center">

        <button type="button" onclick="history.back()" class="cursor-pointer">
            <img class="object-contain sm:w-7 s:w-5 xs:w-5"
                 src="{{ file_url('themes/engage/images/main/reverse-arrow.svg') }}"
                 alt="Go back">
        </button>

        <h1 class="md:text-5xl sm:text-xl s:text-xl xs:text-xl text-center md:mt-12 md:mb-20 mt-8 mb-8 font-bold">
            Ideas
        </h1>
        <div></div>
    </div>

    <div class="blogs">
        <div class="blogs-content">
            <div class="card blog-page">

                <div class="relative">
                    {% set uri = content.field_idea_image['#items'][0].entity.uri.value %}
                    <img src="{{ file_url(uri) }}"
                         alt="{{ node.title.value }}"
                         class="blog-page-img">
                </div>

                <div class="card-body px-0 py-3">
                    <h2 class="card-title text-3xl text-dark font-bold font-['nevis'] s:text-xl xs:text-base">
                        {{ node.title.value }}
                    </h2>

                    <div class="card-desc details_desc my-3 s:text-base xs:text-sm">
                        {{ node.field_idea_content.value | raw }}
                    </div>
                </div>

                <div class="rates">
                    {{ content.field_rating }}
                </div>

            </div>
        </div>
    </div>
</div>
