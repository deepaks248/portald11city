{% macro menu_links(items, attributes, menu_level) %}
  {% import _self as menus %}
  {% if items %}
    {% if menu_level == 0 %}
      <ul{{ attributes.addClass('space-y-4 md:space-y-0 md:flex md:space-x-6') }}>
    {% else %}
      <ul class="ml-4 space-y-2">
    {% endif %}
      
      {% for item in items %}
        <li{{ item.attributes.addClass('group relative') }}>
          <a href="{{ item.url }}" class="block text-black border-2 border-stone-300 rounded-md px-3 py-2 sm:text-lg sm:font-semibold sm:text-white sm:hover:text-yellow-400 sm:border-none sm:p-0 sm:transition sm:duration-200">
            {{ item.title|t }}
          </a>
          {% if item.below %}
            {{ menus.menu_links(item.below, attributes, menu_level + 1) }}
          {% endif %}
        </li>
      {% endfor %}
      
      {% if logged_in and is_admin %}
        <li class="group relative block lg:hidden">
          <a href="/user/logout" class="block text-black border-2 border-stone-300 rounded-md px-3 py-2 sm:text-lg sm:font-semibold sm:text-white sm:hover:text-yellow-400 sm:border-none sm:p-0 sm:transition sm:duration-200">
            {{ 'Logout'|t }}
          </a>
        </li>
      {% elseif logged_in and not is_admin %}
        <li class="group relative block lg:hidden">
          <a href="/logout" class="block text-black border-2 border-stone-300 rounded-md px-3 py-2 sm:text-lg sm:font-semibold sm:text-white sm:hover:text-yellow-400 sm:border-none sm:p-0 sm:transition sm:duration-200">
            {{ 'Logout'|t }}
          </a>
        </li>
      {% else %}
        <li class="group relative block lg:hidden">
          <a href="/user-login" class="block text-black border-2 border-stone-300 rounded-md px-3 py-2 sm:text-lg sm:font-semibold sm:text-white sm:hover:text-yellow-400 sm:border-none sm:p-0 sm:transition sm:duration-200">
            {{ 'Login/Sign up'|t }}
          </a>
        </li>
      {% endif %}
    </ul>
  {% endif %}
{% endmacro %} #}

{% import _self as menus %}
{% set isadmin = is_admin %}
{% set loggedin = logged_in %}

{{ menus.menu_links(items, attributes, 0, loggedin, isadmin) }}

{% macro menu_links(items, attributes, menu_level, loggedin, isadmin) %}
  {% import _self as menus %}
  {% if items %}
    {% if menu_level == 0 %}
      <ul{{ attributes.addClass('space-y-4 md:space-y-0 md:flex md:space-x-6') }}>
    {% else %}
      <ul class="ml-4 space-y-2">
    {% endif %}

    {% for item in items %}
      <li{{ item.attributes.addClass('group relative') }}>
        <a href="{{ item.url }}" class="block text-black border-2 border-stone-300 rounded-md px-3 py-2 sm:text-lg sm:font-semibold sm:text-white sm:hover:text-yellow-400 sm:border-none sm:p-0 sm:transition sm:duration-200">
          {{ item.title|t }}
        </a>
        {% if item.below %}
          {{ menus.menu_links(item.below, attributes, menu_level + 1, loggedin, isadmin) }}
        {% endif %}
      </li>
    {% endfor %}

    {% if loggedin and isadmin %}
      <li class="group relative block lg:hidden">
        <a href="/user/logout" class="block text-black border-2 border-stone-300 rounded-md px-3 py-2 sm:text-lg sm:font-semibold sm:text-white sm:hover:text-yellow-400 sm:border-none sm:p-0 sm:transition sm:duration-200">
          {{ 'Logout'|t }}
        </a>
      </li>
