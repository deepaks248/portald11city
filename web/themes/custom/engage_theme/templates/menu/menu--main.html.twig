        <a href="/logout" class="block text-black border-2 border-stone-300 rounded-md px-3 py-2 sm:text-lg sm:font-semibold sm:text-white sm:hover:text-yellow-400 sm:border-none sm:p-0 sm:transition sm:duration-200">
