{# {{ dump(path('<current>')) }} #}
{% if path('<current>') == '/user-login' or path('<current>') == '/user-register' or path('<current>') == '/validate-password' %}
	<div>
		{{  page.content }}
	</div>
{% else %}
	<div class="mx-auto max-w-screen-xl topbar bg-white py-2 px-4">
		<div
			class="flex flex-wrap items-center justify-between gap-4 w-full">
			<!-- Left section (header region: language + search) -->
			{{ page.header }}
			<!-- Right section (download + social links) -->
			<div class="flex flex-wrap items-center gap-2 lg:gap-4 xl:gap-20 2xl:gap-24">
				<div class="download-link flex items-end gap-3 hidden lg:flex">
					<p class="font-sans text-xs font-bold text-dark px-1 hidden xl:block translateLabel" label-alias="la_download_city_app">
						Download City App:
					</p>

					<a href="https://play.google.com/store/apps/" target="_blank" rel="noopener noreferrer">
						<img src="/themes/custom/engage_theme/images/social/android.svg" alt="Google Play" class="" width="17" height="20">
					</a>

					<a href="https://apps.apple.com/in/app/" target="_blank" rel="noopener noreferrer">
						<img src="/themes/custom/engage_theme/images/social/iphone.svg" alt="App Store" class="" width="17" height="20">
					</a>
				</div>

				<div class="social-link flex items-center gap-3">
					<p class="font-sans text-xs font-bold text-dark px-1 translateLabel" label-alias="la_follow_us">
						Follow us:
					</p>

					<!-- Facebook -->
					<a href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer">
						<img src="/themes/custom/engage_theme/images/social/fb.svg" alt="Facebook" class="" width="11" height="20">
					</a>
					<!-- Twitter -->
					<a href="https://twitter.com/" target="_blank" rel="noopener noreferrer">
						<img src="/themes/custom/engage_theme/images/social/twitter.svg" alt="Twitter" class="" width="22" height="18">
					</a>
					<!-- Instagram -->
					<a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer">
						<img src="/themes/custom/engage_theme/images/social/instagram.svg" alt="Instagram" class="" width="20" height="20">
					</a>
				</div>
			</div>
		</div>
	</div>
	<header class="bg-black shadow">
		<div
			class="px-4 flex items-center justify-between mx-auto max-w-screen-xl">
			<!-- Branding -->
			<div class="branding flex items-center space-x-2">
				{{ drupal_block('system_branding_block') }}
			</div>

			<!-- Desktop Menu -->
			<nav class="hidden md:block">
				{{ drupal_menu('main') }}
			</nav>

			<div class="open-id-connect hidden md:block">
				{% if logged_in %}
					{{ drupal_block('logged_in_details') }}
				{% else %}
					<a class="bg-yellow-500 text-white font-nevis rounded-full px-6 py-2 hover:bg-yellow-600 transition" href="/user-login">
						{{ 'Login/Sign up'|t }}
					</a>
				{% endif %}
			</div>

			<button id="menu-toggle" class="md:hidden text-white focus:outline-none ml-auto" aria-label="Toggle menu">
				<svg class="w-8 h-8" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
				</svg>
			</button>
		</div>

		<!-- Mobile Slide-out Menu (Right Tray) -->
		<div id="mobile-menu" class="fixed top-0 right-0 h-full w-64 bg-white text-black shadow-lg transform translate-x-full transition-transform duration-300 ease-in-out z-40 md:hidden">
			<div class="flex justify-between items-center p-4 border-b border-gray-700">
				<span class="text-lg font-bold">{{ 'CitizenPortal'|t }}</span>
				<button id="menu-close" aria-label="Close menu">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
					</svg>
				</button>
			</div>
			<nav class="p-4 space-y-4">
				{{ drupal_menu('main') }}
			</nav>
		</div>

		<!-- Optional: Backdrop -->
		<div id="backdrop" class="fixed inset-0 bg-black bg-opacity-50 hidden z-30 md:hidden"></div>
	</header>
	{# {{ page.primary_menu }} #}
	{{ page.highlighted }}
	{{ page.help }}
	<div class="">
		{% if page.sidebar %}
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
				<main class="lg:col-span-8">
					{{ page.content }}
				</main>
				<aside class="lg:col-span-4">
					{{ page.sidebar }}
				</aside>
			</div>
		{% else %}
			<div>
				{{ page.content }}
			</div>
		{% endif %}
	</div>

	{# {% if page.footer %} #}
	<footer class="page-footer bg-black px-4 py-8 sm:px-6 lg:px-10">
		<div
			class="mx-auto max-w-screen-xl">
			<!-- Top row: logo or other footer blocks -->
			<div class="flex flex-col sm:flex-row justify-between items-center sm:items-start gap-6 pb-10">
				{{ page.footer }}
			{# Optional block like user_visit_count_block #}
				{# {{ drupal_block('user_visit_count_block') }} #}
			</div>

			<!-- Footer main sections -->
			<div class="footer grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-8 sm:gap-10">
				{% if page.footer_first %}
					<div class="col-span-12 lg:col-span-4 leading-8 text-[#fdfcfa] opacity-70">
						{{ page.footer_first }}
					</div>
				{% endif %}

				{% if page.footer_second %}
					<div class="col-span-6 sm:col-span-1 lg:col-span-2 ps-2 sm:ps-6 text-[#fdfcfa] opacity-70">
						{{ page.footer_second }}
					</div>
				{% endif %}

				{% if page.footer_third %}
					<div class="col-span-6 sm:col-span-1 lg:col-span-2 ps-2 sm:ps-6 text-[#fdfcfa] opacity-70">
						{{ page.footer_third }}
					</div>
				{% endif %}

				{% if page.footer_fourth %}
					<div class="col-span-12 lg:col-span-4 ps-2 sm:ps-8 text-[#fdfcfa] opacity-70">
						{{ page.footer_fourth }}
					</div>
				{% endif %}
			</div>
		</div>
	</footer>

{% endif %}
