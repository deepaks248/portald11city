{# {{ dump(path('<current>')) }} #}
{% if path('<current>') == '/user-login' or path('<current>') == '/user-register' or path('<current>') == '/validate-password' %}
	<div>
		{{  page.content }}
	</div>
{% else %}
	<div class="mx-auto max-w-screen-xl topbar bg-white py-2 px-4">
		<div class="flex flex-wrap items-center justify-between gap-4 w-full">
			{{ page.header }}
		</div>
	</div>
	<header class="bg-black shadow">
		<div
			class="px-4 flex items-center justify-between mx-auto max-w-screen-xl">
			<!-- Branding -->
			<div class="branding flex items-center space-x-2">
				{{ drupal_block('system_branding_block') }}
			</div>

			<!-- Desktop Menu -->
			<nav class="hidden md:block">
				{{ drupal_menu('main') }}
			</nav>

			<div class="open-id-connect hidden md:block">
				{% if logged_in %}
					<div class="relative inline-block text-left group">
						<button class="flex items-center gap-2 bg-yellow-400 hover:bg-yellow-500 text-white font-bold py-2 px-4 rounded-full focus:outline-none">
							<span class="truncate max-w-[8rem]">{{ user.display_name }}</span>
							<img src="/sites/default/files/2025-07/default-avatar-profile-icon-vector-39013212.jpg" alt="User Avatar" class="w-6 h-6 rounded-full object-cover">
						</button>

						<div
							class="absolute right-0 z-50 mt-2 w-64 origin-top-right rounded-xl bg-white shadow-lg ring-1 ring-black ring-opacity-5 opacity-0 group-hover:opacity-100 transition-all duration-200 pointer-events-none group-hover:pointer-events-auto">
							<!-- Profile Info -->
							<div class="p-4 border-b">
								<div class="flex items-center gap-3">
									<img src="/sites/default/files/2025-07/default-avatar-profile-icon-vector-39013212.jpg" alt="User Avatar" class="w-10 h-10 rounded-full object-cover">
									<div class="min-w-0">
										<p class="font-semibold text-gray-800 truncate">{{ user.display_name }}</p>
										<p class="text-sm text-gray-500 break-words whitespace-normal">{{ user.mail }}</p>
									</div>
								</div>
							</div>

							<!-- Links -->
							<div class="px-4 py-2 space-y-1">
								<a href="/my-account" class="block py-1 text-gray-800 hover:text-yellow-500">{{ 'My Profile'|t }}</a>
								<a href="/service-request" class="block py-1 text-gray-800 hover:text-yellow-500">{{ 'My Requests'|t }}</a>
								<a href="/survey" class="block py-1 text-gray-800 hover:text-yellow-500">{{ 'Survey'|t }}</a>
							</div>

							<!-- Logout -->
							<div class="border-t px-4 py-2">
								<a href="/logout" class="flex items-center gap-2 text-gray-800 hover:text-red-600">
									<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1"/>
									</svg>
									<span>{{ 'Log Out'|t }}</span>
								</a>
							</div>
						</div>
					</div>
				{% else %}
					<a class="bg-yellow-500 text-white font-nevis rounded-full px-6 py-2 hover:bg-yellow-600 transition" href="/user-login">
						{{ 'Login/Sign up'|t }}
					</a>
				{% endif %}
			</div>

			<button id="menu-toggle" class="md:hidden text-white focus:outline-none ml-auto" aria-label="Toggle menu">
				<svg class="w-8 h-8" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
				</svg>
			</button>
		</div>

		<!-- Mobile Slide-out Menu (Right Tray) -->
		<div id="mobile-menu" class="fixed top-0 right-0 h-full w-64 bg-white text-black shadow-lg transform translate-x-full transition-transform duration-300 ease-in-out z-40 md:hidden">
			<div class="flex justify-between items-center p-4 border-b border-gray-700">
				<span class="text-lg font-bold">{{ 'CitizenPortal'|t }}</span>
				<button id="menu-close" aria-label="Close menu">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
					</svg>
				</button>
			</div>
			<nav class="p-4 space-y-4">
				{{ drupal_menu('main') }}
			</nav>
		</div>

		<!-- Optional: Backdrop -->
		<div id="backdrop" class="fixed inset-0 bg-black bg-opacity-50 hidden z-30 md:hidden"></div>
	</header>
	{# {{ page.primary_menu }} #}
	{{ page.highlighted }}
	{{ page.help }}
	<div class="">
		{% if page.sidebar %}
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
				<main class="lg:col-span-8">
					{{ page.content }}
				</main>
				<aside class="lg:col-span-4">
					{{ page.sidebar }}
				</aside>
			</div>
		{% else %}
			<div>
				{{ page.content }}
			</div>
		{% endif %}
	</div>

	{# {% if page.footer %} #}
	<footer class="page-footer bg-black px-4 py-8 sm:px-6 lg:px-10">
		<div
			class="mx-auto max-w-screen-xl">
			<!-- Top row: logo or other footer blocks -->
			<div class="flex flex-col sm:flex-row justify-between items-center sm:items-start gap-6 pb-10">
				{{ page.footer }}
			{# Optional block like user_visit_count_block #}
				{# {{ drupal_block('user_visit_count_block') }} #}
			</div>

			<!-- Footer main sections -->
			<div class="footer grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-8 sm:gap-10">
				{% if page.footer_first %}
					<div class="col-span-12 lg:col-span-4 leading-8 text-[#fdfcfa] opacity-70">
						{{ page.footer_first }}
					</div>
				{% endif %}

				{% if page.footer_second %}
					<div class="col-span-6 sm:col-span-1 lg:col-span-2 ps-2 sm:ps-6 text-[#fdfcfa] opacity-70">
						{{ page.footer_second }}
					</div>
				{% endif %}

				{% if page.footer_third %}
					<div class="col-span-6 sm:col-span-1 lg:col-span-2 ps-2 sm:ps-6 text-[#fdfcfa] opacity-70">
						{{ page.footer_third }}
					</div>
				{% endif %}

				{% if page.footer_fourth %}
					<div class="col-span-12 lg:col-span-4 ps-2 sm:ps-8 text-[#fdfcfa] opacity-70">
						{{ page.footer_fourth }}
					</div>
				{% endif %}
			</div>
		</div>
	</footer>

{% endif %}
