{#
/**
 * @file
 * Theme override for main view template.
 */
#}

{% set classes = [ dom_id ? 'js-view-dom-id-' ~ dom_id ] %}

<div{{attributes.addClass(classes)}}>
	<div class="faq-page mx-auto max-w-screen-xl bg-white mb-32 px-4 py-6">

		{{ title_prefix }}
		{{ title }}
		{{ title_suffix }}

		{% if header %}
			<header>
				{{ header }}
			</header>
		{% else %}
			<div class="contenting container mx-auto relative xs:p-5 xs:mt-0 xs:mb-0 s:mt-0 s:mb-0">
				<div class="flex justify-center">
					<div class="container my-ideas-wrapper">
						<div
							class="flex justify-between items-center">

							<!-- Accessible Back Button -->
							<button type="button" aria-label="Go back" onclick="window.history.back();" class="w-5 sm:w-7 object-contain cursor-pointer p-0 bg-transparent border-none" style="background:none; border:none;">
								<img src="themes/custom/engage_theme/images/Profile/reverse-arrow.svg" alt="Back" class="w-full h-auto object-contain"/>
							</button>

							<!-- Heading -->
							<h1 class="text-4xl md:text-5xl font-nevis text-center mt-8 md:mt-12 mb-8 md:mb-20 translateLabel search_field" label-alias="la_my_profile">
								Ideas
							</h1>

							<!-- Placeholder for symmetry -->
							<div class="w-5 sm:w-7"></div>
						</div>
					</div>
				</div>
			</div>
		{% endif %}

		<div class="solid border-solid mb-[45px] pb-[45px] border-b-[2px] border-[#3333] bg-white">
			{{ exposed }}
			{{ attachment_before }}
		</div>

		<div class="xs:hidden s:hidden solid border-solid border-2 rounded-2xl p-5 bg-white">

			{% if logged_in %}
				<div class="text-right flex justify-end">
					<button type="button" class="btn flex gap-2 p-[4px] md:p-[10px] text-white text-xl capitalize font-bold font-['Open_Sans'] mb-4 bg-[#ffcc00] rounded-[4px] md:rounded-[10px] cursor-pointer" onclick="window.location.href='add-ideas';">
						<img class="object-contain w-6" src="themes/custom/engage_theme/images/Ideas/plus_mark.svg" alt="Add new idea">
						Submit New Idea
					</button>
				</div>
			{% endif %}

			<div class="flex flex-col overflow-y-auto h-full md:max-h-[700px]" id="news_list">

				{% if rows %}
					{{ rows }}
				{% elseif empty %}
					{{ empty }}
				{% endif %}

			</div>
		</div>

		<div class="mt-4">
			{{ pager }}
			{{ attachment_after }}
			{{ more }}
		</div>

		{% if footer %}
			<footer>
				{{ footer }}
			</footer>
		{% endif %}

		{{ feed_icons }}

	</div>
</div>
